# Required
PUID=1000
PGID=1000
TZ=Etc/UTC

# Database
DATABASE_URL=sqlite:////config/deduparr.db

# Logging
LOG_LEVEL=INFO

# Optional: Plex SQLite DB path (for direct query method)
PLEX_DB_PATH=/plex-config/Library/Application Support/Plex Media Server/Plug-in Support/Databases/com.plexapp.plugins.library.db

# Optional: Scheduled scans
ENABLE_SCHEDULED_SCANS=false
SCAN_INTERVAL_HOURS=24

# Docker Compose volume paths
CONFIG_PATH=./config
# PLEX_CONFIG_PATH=/path/to/plex/config
# MEDIA_PATH=/path/to/media
# UI_PORT=8655
